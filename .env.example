# AutoAIBlog 环境变量配置示例
# 复制此文件为 .env 并填入你自己的 API 密钥

# Anthropic Claude API（用于驱动所有 Agent）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1

# Tavily 搜索 API（用于 AI 企业资讯、HCI、AI 工具推荐板块）
# 申请地址：https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI（可选，用于补充搜索）
# 申请地址：https://serpapi.com
SERPER_API_KEY=your_serper_api_key_here

# CrewAI 使用的 LLM 配置（指向 Claude）
MODEL=claude-sonnet-4-6

# Notion Integration Secret（用于将文章发布到 Notion）
NOTION_INTEGRATION_SECRET=your_notion_integration_secret_here
NOTION_PAGE_ID=your_notion_page_id_here
